# Bot configuration
BOT_TOKEN=your_bot_token_here

# Webhook configuration
USE_WEBHOOK=false
WEBHOOK_DOMAIN=https://your-domain.com

# Database configuration
MONGODB_URI=mongodb://mongodb:27017/bikebot

# Environment configuration
NODE_ENV=development
DEFAULT_LANGUAGE=en
FALLBACK_LANGUAGE=en
DEFAULT_TIMEZONE=Europe/Warsaw

# Strava API (optional; enables API-based route/activity parsing)
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# Telegram full E2E testing
E2E_TELEGRAM_API_ID=your_telegram_api_id_here
E2E_TELEGRAM_API_HASH=your_telegram_api_hash_here
E2E_TELEGRAM_SESSION=
E2E_PRIMARY_GROUP_ID=
